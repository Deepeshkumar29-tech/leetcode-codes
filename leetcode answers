    }
}
//leetcode 476
class Solution {
    public int findComplement(int num) {
        int rem,ans=0;
        long mul=1;
        if (num==0) return 1;
        while(num>0) {
            rem=num%2;
            rem^=1;   
            num/=2;
            ans=(int)(ans+rem*mul);
            mul*=2;
        }
        return ans;
    }
}
//leetcode 397
class Solution {
    public int integerReplacement(int n) {
        long temp=n; 
        int count=0;
        while (temp!=1){
            if (temp%2==0){
                temp/=2;
            }else if(temp==3||temp%4==1) {
                    temp--;
                }else{
                    temp++;
                }
            count++;
        }
        return count;
    }
}
//leetcode 326
class Solution {
    public boolean isPowerOfThree(int n) {
        long temp=1;
       while(n>1&&temp<n)
       {
           temp+=temp<<1; 
       }
       return temp==n;
   }
    }
//leetcode 190
class Solution {
    public int reverseBits(int n) {
        int res=0;
        for(int i=0;i<32;i++){
            int l=n&1;
            int t=l<<(31-i);
            res=res|t;
            n=n>>1;
        }
        return res;
    }
}

