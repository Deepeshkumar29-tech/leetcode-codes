//leetcode2652

Class Solution {
    public int sumOfMultiples(int n) {
        int s=0;
        while(n>0){ 
            if(n%3==0||n%5==0||n%7==0){
                s+=n;
            }
            n--;
        }
        return s;
    }
}
//leetcode 009
class Solution {
    public boolean isPalindrome(int x) {
         if (x<0) {
            return false;
        }
        int rev=0;
        int a=x;
        while(x>0) {
            rev=(rev*10)+(x%10);
            x/=10;
        }
        return rev==a;    
    }
}
//leetcode 007
class Solution {
    public int reverse(int x) {
        long rev=0;
        while(x!=0){
            int d=x%10;
            rev=rev*10+d;
            x=x/10;
        }if(rev>Integer.MAX_VALUE||rev<Integer.MIN_VALUE) return 0;
        return (int)rev;
    }
}
//leetcode 2739
class Solution {
    public int distanceTraveled(int mainTank, int additionalTank) {
        int fc=0;
        int count=0;
        while(mainTank>0) {
            count++;
            if(count==5) {
                count=0;
                if(additionalTank>0) {
                    mainTank++;
                    additionalTank--;
                }
            }
            fc++;
            mainTank--;
        }
        int res=fc*10;
        return res;
    }
}
//leetcode 1952
class Solution {
    public boolean isThree(int n) {
        int div=0;
        for(int i=1;i<=n;i++){
            if(n%i==0){
                div++;
                if(div>3) return false;
            }
        }
        return div==3;
    }
}
